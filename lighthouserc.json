{
  "ci": {
    "collect": {
      "startServerCommand": "uv run python -u manage.py runserver 127.0.0.1:8765 --noreload",
      "startServerReadyPattern": "Quit the server",
      "startServerReadyTimeout": 60000,
      "url": [
        "http://127.0.0.1:8765/",
        "http://127.0.0.1:8765/how-it-works/",
        "http://127.0.0.1:8765/faq/",
        "http://127.0.0.1:8765/register/",
        "http://127.0.0.1:8765/legal/privacy/"
      ],
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox --headless=new"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.75 }],
        "categories:accessibility": ["error", { "minScore": 0.8 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.85 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./lighthouse-reports"
    }
  }
}
