# Copy to .env and fill in. Loaded via python-decouple. Never commit .env.

# Development (config.settings.development) runs with insecure defaults and
# SQLite, so .env is optional locally. Override SECRET_KEY if you wish:
# SECRET_KEY=change-me

# --- Production (config.settings.production) ---
# DJANGO_SETTINGS_MODULE=config.settings.production
# SECRET_KEY=generate-a-long-random-value
# ALLOWED_HOSTS=ambassadeurs.example.com
# CSRF_TRUSTED_ORIGINS=https://ambassadeurs.example.com
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Matching / registration window ---
# Leave these unset (dev defaults: window always open) or override:
# CONTACT_WINDOW_HOURS=72
# Dates only (YYYY-MM-DD); both bounds inclusive. Time/timezone are ignored.
# REGISTRATION_OPENS_AT=2026-09-01
# REGISTRATION_CLOSES_AT=2026-10-31

# --- Application form ---
# Externally-hosted application-form PDF the download view redirects to.
# Defaults to the current 4 Vallées URL; override if it moves.
# APPLICATION_FORM_URL=https://verbier4vallees.ch/V4V-Website/Documents/Parrainage/AMBASSADOR_V4V_26_27.pdf

# --- Email (production SMTP) ---
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=Ambassadeurs <noreply@example.com>
