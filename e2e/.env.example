# Copy to e2e/.env for local runs. In CI these are set by the workflow.

# The running app under test (never point this at production).
BASE_URL=http://127.0.0.1:8000

# Mailpit HTTP API — where the suite reads delivered mail back from.
MAILPIT_URL=http://127.0.0.1:8025

# Set to skip Playwright's built-in Django webServer (CI starts it by hand).
# Leave unset locally to have Playwright boot Django for you.
# PW_NO_WEBSERVER=1
