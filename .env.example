# Copy to .env and fill in. Loaded via python-decouple. Never commit .env.

# Development (config.settings.development) runs with insecure defaults and
# SQLite, so .env is optional locally. Override SECRET_KEY if you wish:
# SECRET_KEY=change-me

# --- Production (config.settings.production) ---
# DJANGO_SETTINGS_MODULE=config.settings.production
# SECRET_KEY=generate-a-long-random-value
# ALLOWED_HOSTS=ambassadeurs.example.com
# CSRF_TRUSTED_ORIGINS=https://ambassadeurs.example.com
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Site base URL ---
# Absolute URL used to build links in emails sent without a request context.
# BASE_URL=https://ambassadeurs.example.com

# --- Matching / registration window ---
# Leave these unset (dev defaults: window always open) or override:
# CONTACT_WINDOW_HOURS=72
# Dates only (YYYY-MM-DD); both bounds inclusive. Time/timezone are ignored.
# REGISTRATION_OPENS_AT=2026-09-01
# REGISTRATION_CLOSES_AT=2026-10-31
# Full ISO 8601 datetime; matching is held back until this moment even though
# registration itself may already be open (deferred matching, VERB-82).
# MATCHING_OPENS_AT=2026-11-01T00:00:00+01:00
# Comma-separated "YYYY-MM-DD:CHF" thresholds; each means "from this date
# onward the fee is N CHF" (tiered prepaid registration fee, VERB-82).
# REGISTRATION_FEE_TIERS=2026-10-01:5,2026-11-01:10,2026-12-01:20

# --- Application form ---
# Externally-hosted application-form PDF the download view redirects to.
# Defaults to the current 4 Vallées URL; override if it moves.
# APPLICATION_FORM_URL=https://verbier4vallees.ch/V4V-Website/Documents/Parrainage/AMBASSADOR_V4V_26_27.pdf

# --- Email (production SMTP) ---
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=Ambassadeurs <noreply@example.com>

# --- MaxMind GeoLite2 (geolocation) ---
# Sign up for a free account at https://www.maxmind.com/en/geolite2/signup
# build.sh downloads the database when BOTH MAXMIND_ACCOUNT_ID and
# MAXMIND_LICENSE_KEY are set (MaxMind authenticates as account_id:license_key).
# Leave unset locally to disable geolocation (registration_country/region
# will be stored as empty strings).
# MAXMIND_ACCOUNT_ID=your_account_id_here
# MAXMIND_LICENSE_KEY=your_license_key_here
# GEOIP_DATABASE_PATH=/path/to/geoip/GeoLite2-City.mmdb
