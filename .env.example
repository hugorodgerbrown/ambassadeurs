# Copy to .env and fill in. Loaded via python-decouple. Never commit .env.

# Development (config.settings.development) runs with insecure defaults and
# SQLite, so .env is optional locally. Override SECRET_KEY if you wish:
# SECRET_KEY=change-me

# Setting DATABASE_URL here points `tox -e test` (and local dev) at Postgres
# instead of the SQLite default — the same lane CI runs on every PR (ADR 0019).
# Optional; leave unset to keep using SQLite.
# DATABASE_URL=postgres://ambassadeurs:ambassadeurs@127.0.0.1:5432/ambassadeurs_test

# --- Production (config.settings.production) ---
# DJANGO_SETTINGS_MODULE=config.settings.production
# SECRET_KEY=generate-a-long-random-value
# ALLOWED_HOSTS=ambassadeurs.example.com
# CSRF_TRUSTED_ORIGINS=https://ambassadeurs.example.com
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Admin subdomain (ADR 0022) ---
# Set ADMIN_HOST to serve the Django admin ONLY on its own subdomain (admin at
# the root of that host), with /admin/ removed from the main site. The admin host
# must ALSO be appended to ALLOWED_HOSTS and, as https://, to
# CSRF_TRUSTED_ORIGINS. Leave unset to keep the admin at /admin/ on the main
# domain (the single-host default).
# ADMIN_HOST=admin.example.com
# ALLOWED_HOSTS=ambassadeurs.example.com,admin.example.com
# CSRF_TRUSTED_ORIGINS=https://ambassadeurs.example.com,https://admin.example.com

# --- Site base URL ---
# Absolute URL used to build links in emails sent without a request context.
# BASE_URL=https://ambassadeurs.example.com

# --- Matching / registration window ---
# Leave these unset (dev defaults: window always open) or override:
# CONTACT_WINDOW_HOURS=72
# Dates only (YYYY-MM-DD); both bounds inclusive. Time/timezone are ignored.
# REGISTRATION_OPENS_AT=2026-09-01
# REGISTRATION_CLOSES_AT=2026-10-31
# Full ISO 8601 datetime; matching is held back until this moment even though
# registration itself may already be open (deferred matching, VERB-82).
# MATCHING_OPENS_AT=2026-11-01T00:00:00+01:00
# Comma-separated "YYYY-MM-DD:CHF" thresholds; each means "from this date
# onward the fee is N CHF" (tiered prepaid registration fee, VERB-82).
# REGISTRATION_FEE_TIERS=2026-10-01:5,2026-11-01:10,2026-12-01:20

# --- Internationalisation (ADR 0016) ---
# Untranslated/fuzzy catalogue entries (across locales) at which the review
# machinery opens an "update translation catalogues" task. Default 10.
# I18N_UPDATE_MESSAGES_THRESHOLD=10

# --- Stripe (billing deposit, VERB-85) ---
# Prepaid registration deposit collection (ADR 0014). Leave unset locally —
# billing.services.payments only calls Stripe from refund(); capture() and
# forfeit() are pure state transitions and never touch the network.
# STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# STRIPE_CURRENCY=chf
# Signing secret for the checkout.session.completed webhook (VERB-86).
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# --- Application form ---
# Externally-hosted application-form PDF the download view redirects to.
# Defaults to the current 4 Vallées URL; override if it moves.
# APPLICATION_FORM_URL=https://verbier4vallees.ch/V4V-Website/Documents/Parrainage/AMBASSADOR_V4V_26_27.pdf

# --- Email (production SMTP) ---
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=Ambassadeurs <noreply@example.com>

# --- MaxMind GeoLite2 (geolocation) ---
# Sign up for a free account at https://www.maxmind.com/en/geolite2/signup
# build.sh downloads the database when BOTH MAXMIND_ACCOUNT_ID and
# MAXMIND_LICENSE_KEY are set (MaxMind authenticates as account_id:license_key).
# Leave unset locally to disable geolocation (registration_country/region
# will be stored as empty strings).
# MAXMIND_ACCOUNT_ID=your_account_id_here
# MAXMIND_LICENSE_KEY=your_license_key_here
# GEOIP_DATABASE_PATH=/path/to/geoip/GeoLite2-City.mmdb

# --- Error monitoring (PostHog, production only) ---
# Server-side exception capture. Leave unset in development — monitoring is a
# no-op without POSTHOG_API_KEY. Email/phone are scrubbed from every event and
# stack-frame locals are never captured (see core/observability.py).
# POSTHOG_API_KEY=phc_your_project_api_key_here
# POSTHOG_HOST=https://eu.i.posthog.com
